{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "image-slot.js",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:EB Garamond|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: EB Garamond, Inter, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--border-hair",
      "--border-moss",
      "--bronze",
      "--charcoal",
      "--cream",
      "--dark-bg",
      "--dark-hairline",
      "--dark-surface",
      "--fs-body",
      "--fs-caption",
      "--fs-h1",
      "--fs-h2",
      "--fs-h3",
      "--fs-hero",
      "--fs-lead",
      "--fs-quote",
      "--fs-small",
      "--gold",
      "--hairline",
      "--lh-body",
      "--lh-loose",
      "--lh-snug",
      "--lh-tight",
      "--mono",
      "--moss",
      "--offwhite",
      "--radius-0",
      "--radius-pill",
      "--radius-sm",
      "--s-1",
      "--s-2",
      "--s-3",
      "--s-4",
      "--s-5",
      "--s-6",
      "--s-7",
      "--s-8",
      "--sans",
      "--serif",
      "--shadow-soft",
      "--stone",
      "--surface-1",
      "--surface-2",
      "--text-1",
      "--text-2",
      "--text-3",
      "--text-on-dark-1",
      "--text-on-dark-2",
      "--text-on-moss",
      "--track-caps",
      "--track-logo",
      "--track-mono",
      "--track-tight",
      "--w-med",
      "--w-reg",
      "--w-semi"
    ],
    "tokenKinds": {
      "--moss": "color",
      "--charcoal": "color",
      "--cream": "color",
      "--stone": "color",
      "--bronze": "color",
      "--offwhite": "color",
      "--surface-1": "color",
